{%- doc -%}
  Renders an inline search bar for the header.
  Reuses the inline-search custom element and Section Rendering API.

  @param {string} [placeholder] - Placeholder text for the search input
{%- enddoc -%}

<script src="{{ 'inline-search.js' | asset_url }}" type="module" defer></script>

<inline-search
  class="header-inline-search"
  data-section-id="inline-search"
>
  <div class="header-inline-search__wrap">
    <svg class="header-inline-search__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
    </svg>
    <input
      type="search"
      data-inline-search-input
      placeholder="{{ placeholder | default: 'Search products...' }}"
      autocomplete="off"
      aria-label="{{ placeholder | default: 'Search products...' }}"
    >
  </div>
  <div class="header-inline-search__dropdown" data-inline-search-dropdown hidden></div>
</inline-search>
