{%- doc -%}
  Breadcrumb navigation section.
  Works in collection, product, blog, article, page, search templates.
{%- enddoc -%}

<div class="section color-{{ section.settings.color_scheme }}">
  <nav
    class="breadcrumb-section"
    aria-label="Breadcrumb"
    style="
      --breadcrumb-font-size: {{ section.settings.font_size }};
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    <div class="section section--full-width-margin section--{{ section.settings.section_width }}">
      <ol class="breadcrumb__list">
        <li class="breadcrumb__item">
          <a href="/" class="breadcrumb__link">{{ section.settings.home_label | default: 'Home' }}</a>
        </li>

        {%- if template.name == 'collection' -%}
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
            <span>{{ collection.title }}</span>
          </li>

        {%- elsif template.name == 'product' -%}
          {%- if product.collections.size > 0 -%}
            {%- assign primary_collection = product.collections | first -%}
            <li class="breadcrumb__item">
              <a href="{{ primary_collection.url }}" class="breadcrumb__link">{{ primary_collection.title }}</a>
            </li>
          {%- endif -%}
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
            <span>{{ product.title }}</span>
          </li>

        {%- elsif template.name == 'blog' -%}
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
            <span>{{ blog.title }}</span>
          </li>

        {%- elsif template.name == 'article' -%}
          <li class="breadcrumb__item">
            <a href="{{ blog.url }}" class="breadcrumb__link">{{ blog.title }}</a>
          </li>
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
            <span>{{ article.title }}</span>
          </li>

        {%- elsif template.name == 'page' -%}
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
            <span>{{ page.title }}</span>
          </li>

        {%- elsif template.name == 'search' -%}
          <li class="breadcrumb__item breadcrumb__item--current" aria-current="page">
            <span>Search</span>
          </li>
        {%- endif -%}
      </ol>
    </div>
  </nav>
</div>

{% stylesheet %}
  .breadcrumb-section .breadcrumb__list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--breadcrumb-font-size, 0.75rem);
  }

  .breadcrumb-section .breadcrumb__item {
    display: flex;
    align-items: center;
  }

  .breadcrumb-section .breadcrumb__item + .breadcrumb__item::before {
    content: '';
    display: inline-block;
    width: 5px;
    height: 5px;
    border-right: 1.5px solid currentColor;
    border-top: 1.5px solid currentColor;
    transform: rotate(45deg);
    margin-inline: 8px;
    opacity: 0.4;
  }

  .breadcrumb-section .breadcrumb__link {
    color: rgb(var(--color-foreground-rgb) / 0.6);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .breadcrumb-section .breadcrumb__link:hover {
    color: var(--color-foreground);
  }

  .breadcrumb-section .breadcrumb__item--current span {
    color: var(--color-foreground);
    font-weight: 500;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Breadcrumb",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "home_label",
      "label": "Home label",
      "default": "Home"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Font size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "page-width",
          "label": "Page"
        },
        {
          "value": "full-width",
          "label": "Full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "primary"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}
