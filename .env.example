# Shopify Theme Development
# Copy to .env and fill in. Never commit .env to git.
# Get Theme Access token: Theme Access app or Develop app (Theme templates & Theme files: Read and write)

SHOPIFY_FLAG_STORE=nanugi.myshopify.com
SHOPIFY_CLI_THEME_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Theme to deploy to (from admin URL: .../themes/158823317721/editor)
SHOPIFY_THEME_ID=158823317721
